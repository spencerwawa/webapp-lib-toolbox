# ============================================================
# LLM Stack Environment Configuration
# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit secrets here.
# ============================================================

# --- Ollama -----------------------------------------------
# Docker Hub tag for the ollama image (latest, 0.x.x, etc.)
OLLAMA_DOCKER_TAG=latest
# Host port ollama API is exposed on
OLLAMA_PORT=11434

# --- Open WebUI -------------------------------------------
# Docker image tag (main = latest stable, or pin to a version)
WEBUI_DOCKER_TAG=main
# Host port the Open WebUI chat interface is served on
OPEN_WEBUI_PORT=3000
# Secret key used for session signing — change this!
WEBUI_SECRET_KEY=change-me-in-production
# Set to "true" to enable login/auth, "false" for open access
WEBUI_AUTH=false

# --- GitNexus Web UI (gitnexus-web) ----------------------
# Host port the GitNexus graph explorer UI is served on
GITNEXUS_PORT=8080
# Absolute path to the gitnexus-web source directory (Docker build context)
# Sibling repo: webapp-ui-gitnexus/gitnexus-web
GITNEXUS_WEB_PATH=/absolute/path/to/webapp-ui-gitnexus/gitnexus-web
# Absolute path to this toolbox directory — used to locate Dockerfile paths
WEBAPP_LIB_TOOLBOX_PATH=/absolute/path/to/webapp-lib-toolbox

# --- GitNexus Serve (gitnexus-serve) ----------------------
# Host port for the GitNexus HTTP backend that the web UI connects to
GITNEXUS_SERVE_PORT=4747
# Absolute path to the gitnexus CLI source (webapp-ui-gitnexus/gitnexus)
GITNEXUS_CLI_PATH=/absolute/path/to/webapp-ui-gitnexus/gitnexus
# Path to the host's global ~/.gitnexus directory (registry.json lives here)
# Run `gitnexus analyze` in a repo first, then this dir will be populated
GITNEXUS_REGISTRY_PATH=/Users/your-username/.gitnexus
# Root of your workspace — used in the commented repo mount examples
WORKSPACE_PATH=/absolute/path/to/your/workspace
